{
  "name": "E-Commerce Analytics",
  "dataColors": [
    "#2563EB",
    "#16A34A",
    "#F59E0B",
    "#DC2626",
    "#7C3AED",
    "#0891B2",
    "#475569",
    "#DB2777"
  ],
  "background": "#FFFFFF",
  "foreground": "#111827",
  "tableAccent": "#2563EB",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "fontColor": {
              "solid": {
                "color": "#111827"
              }
            },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "labels": [
          {
            "fontColor": {
              "solid": {
                "color": "#374151"
              }
            },
            "fontSize": 9
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E5E7EB"
              }
            }
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "fontColor": {
              "solid": {
                "color": "#111827"
              }
            },
            "fontSize": 18
          }
        ],
        "categoryLabels": [
          {
            "fontColor": {
              "solid": {
                "color": "#6B7280"
              }
            },
            "fontSize": 9
          }
        ]
      }
    }
  }
}

